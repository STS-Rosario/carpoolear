{
  "name": "Carpoolear",
  "version": "1.0.0",
  "description": "Carpoolear Open Source",
  "author": "STS Rosario",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:web": "cross-env PLATFORM=DESKTOP vite build",
    "build:android": "cross-env PLATFORM=android VITE_ROUTE_BASE='' VITE_HISTORY_MODE=hash vite build --outDir www && npx cap sync android",
    "build:ios": "cross-env PLATFORM=ios VITE_ROUTE_BASE='' VITE_HISTORY_MODE=hash vite build --outDir www && npx cap sync ios",
    "build-capacitor-android-local": "npm run build:android && npx cap run android",
    "preview": "vite preview",
    "lint": "eslint --ext .js,.vue src",
    "lint:fix": "eslint --ext .js,.vue --fix src",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:screenshots": "npx playwright test e2e/screenshots.spec.js",
    "test:e2e:screenshots:update": "npx playwright test e2e/screenshots.spec.js --update-snapshots"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.3",
    "@capacitor/app": "^7.0.2",
    "@capacitor/camera": "^7.0.2",
    "@capacitor/cli": "^6.2.1",
    "@capacitor/core": "^7.4.3",
    "@capacitor/device": "^7.0.2",
    "@capacitor/ios": "^7.4.3",
    "@capacitor/network": "^7.0.2",
    "@capacitor/preferences": "^7.0.2",
    "@capacitor/push-notifications": "^7.0.2",
    "@capacitor/splash-screen": "^7.0.2",
    "@capacitor/status-bar": "^7.0.2",
    "@capacitor/toast": "^7.0.2",
    "@movilizame/vue-jumper": "^2.0.2",
    "@toast-ui/vue-editor": "^3.2.3",
    "@vue/compat": "^3.2",
    "alertifyjs": "^1.10.0",
    "axios": "^0.16.0",
    "chart.js": "^3.9.1",
    "dompurify": "^3.3.1",
    "entities": "^7.0.1",
    "firebase": "^9.19.1",
    "font-awesome": "^4.7.0",
    "leaflet-routing-machine": "^3.2.12",
    "lodash": "^4.17.4",
    "marked": "^4.0.19",
    "moment-timezone": "^0.5.13",
    "pikaday": "^1.6.1",
    "qrcode": "^1.5.3",
    "v-mask": "^1.3.0",
    "vue": "^3.2",
    "vue-analytics": "^3.2.0",
    "vue-chartjs": "^4.1.2",
    "vue-datepicker": "^1.3.0",
    "vue-head": "^2.0.11",
    "vue-i18n": "^9",
    "vue-moment": "^2.0.2",
    "vue-resource": "^1.0.3",
    "vue-router": "4.3.3",
    "vue-strap": "github:wffranco/vue-strap",
    "vue2-google-maps": "^0.7.5",
    "vue2-leaflet": "^1.0.2",
    "vuejs-datepicker": "^0.9.7",
    "vuex": "^4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/compiler-sfc": "^3.2",
    "cross-env": "^5.2.0",
    "eslint": "7.32.0",
    "eslint-config-standard": "^16.0.3",
    "eslint-plugin-html": "^7.1.0",
    "eslint-plugin-import": "^2.25.4",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^5.2.0",
    "postcss-import": "^11.1.0",
    "postcss-preset-env": "^6.7.0",
    "vite": "^7.3.1"
  },
  "engines": {
    "node": ">= 16.0.0",
    "npm": ">= 7.0.0"
  },
  "browserslist": [
    "defaults",
    "not dead",
    "not ie > 0"
  ]
}
