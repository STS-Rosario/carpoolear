{
  "name": "Carpoolear",
  "version": "1.0.0",
  "description": "Carpoolear Open Source",
  "author": "STS Rosario",
  "private": true,
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "node movilizame serve",
    "prod": "node movilizame serve --prod",
    "build": "node movilizame build --prod",
    "build:ios": "node movilizame prepare --prod --platform=ios",
    "build:android": "node movilizame build --prod --platform=android",
    "build:web": "node movilizame build-web --prod",
    "build-dev": "node movilizame build",
    "build-dev:ios": "node movilizame build --platform=ios",
    "build-dev:android": "node movilizame build --platform=android",
    "build-capacitor-android-local": "npm run build:android && cp -r dist/default/production/www/* www/ && npx cap run android --target d59fb3c7",
    "lint": "eslint --ext .js -f ./node_modules/eslint-friendly-formatter src",
    "lint:fix": "eslint --ext .js -f ./node_modules/eslint-friendly-formatter --fix src",
    "test:e2e": "npx playwright test",
    "test:e2e:only": "npx playwright test --project=e2e",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:screenshots": "npx playwright test --project=frontend e2e-frontend/screenshots.spec.js",
    "test:e2e:screenshots:update": "npx playwright test --project=frontend e2e-frontend/screenshots.spec.js --update-snapshots",
    "test:frontend": "npx playwright test --project=frontend",
    "test:frontend:ui": "npx playwright test --project=frontend --ui",
    "test:unit": "vitest"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.3",
    "@capacitor/app": "^7.0.2",
    "@capacitor/camera": "^7.0.2",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^7.4.3",
    "@capacitor/device": "^7.0.2",
    "@capacitor/ios": "^7.4.3",
    "@capacitor/network": "^7.0.2",
    "@capacitor/preferences": "^7.0.2",
    "@capacitor/push-notifications": "^7.0.2",
    "@capacitor/splash-screen": "^7.0.2",
    "@capacitor/status-bar": "^7.0.2",
    "@capacitor/toast": "^7.0.2",
    "@capawesome/capacitor-app-update": "^7.2.0",
    "@movilizame/vue-jumper": "^2.0.2",
    "@toast-ui/vue-editor": "^3.2.3",
    "@vue/compat": "^3.2",
    "alertifyjs": "^1.10.0",
    "axios": "^1.15.0",
    "babel-preset-es2015": "^6.24.1",
    "babel-preset-stage-2": "^6.24.1",
    "chart.js": "^3.9.1",
    "core-js": "^3.49.0",
    "dayjs": "^1.11.19",
    "dompurify": "^3.3.2",
    "firebase": "^9.19.1",
    "font-awesome": "^4.7.0",
    "leaflet-routing-machine": "^3.2.12",
    "lodash": "^4.18.1",
    "marked": "^4.0.19",
    "minimist": "^1.2.0",
    "node-notifier": "^5.4.1",
    "pinia": "^2.3.1",
    "qrcode": "^1.5.3",
    "v-mask": "^1.3.0",
    "vue": "^3.2",
    "vue-analytics": "^3.2.0",
    "vue-chartjs": "^4.1.2",
    "vue-datepicker": "^1.3.0",
    "vue-eslint-parser": "^1.0.0",
    "vue-head": "^2.0.11",
    "vue-i18n": "^9",
    "vue-resource": "^1.0.3",
    "vue-router": "4.3.3",
    "vue2-leaflet": "^1.0.2",
    "vuejs-datepicker": "^0.9.7"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/runtime": "^7.29.2",
    "@playwright/test": "^1.58.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/compiler-sfc": "^3.2",
    "autoprefixer": "~8.6.4",
    "babel-eslint": "~8.2.5",
    "babel-plugin-istanbul": "~4.1.6",
    "babel-plugin-transform-runtime": "~6.23.0",
    "chalk": "^1.1.3",
    "cordova": "^13.0.0",
    "cross-env": "^5.2.0",
    "eslint": "7.32.0",
    "eslint-config-airbnb-base": "^14.2.1",
    "eslint-config-standard": "^16.0.3",
    "eslint-import-resolver-webpack": "^0.13.7",
    "eslint-plugin-html": "^7.1.0",
    "eslint-plugin-import": "^2.25.4",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^5.2.0",
    "gulp": "^5.0.1",
    "gulp-if": "^2.0.2",
    "gulp-prompt": "^1.2.0",
    "gulp-rsync": "0.0.7",
    "gulp-util": "^3.0.8",
    "less": "^3.9.0",
    "ora": "^0.3.0",
    "portfinder": "^1.0.21",
    "postcss-import": "^11.1.0",
    "postcss-loader": "^2.1.6",
    "postcss-preset-env": "^6.7.0",
    "semver": "^5.3.0",
    "shelljs": "^0.10.0",
    "terser": "^5.46.1",
    "vite": "^8.0.8",
    "vite-plugin-eslint": "^1.8.1",
    "vite-plugin-static-copy": "^4.0.1",
    "vitest": "^4.1.4",
    "vue-style-loader": "^4.1.0",
    "xml2js": "^0.4.19"
  },
  "browserslist": [
    "defaults and fully supports es6-module",
    ">0.5% in AR and not dead"
  ]
}
