# Copy to .env and edit values

# API
VITE_API_URL="http://carpoolear_backend.test"
# Optional: when building iOS/Android with Capacitor server.hostname matching VITE_API_URL, set a
# different API origin (e.g. www vs apex) so requests are not intercepted by the local bridge.
# VITE_API_URL_NATIVE="https://www.example.com"
VITE_WEB_URL="https://carpoolear.com.ar/app"

# App
VITE_TARGET_APP="carpoolear"
# Empty = default /app/ in vite (production). Set to / for http://localhost:8080/trips in dev (see .env.development).
VITE_ROUTE_BASE=""
VITE_HISTORY_MODE="hash"

# Third-party APIs
VITE_MAPS_API=""
VITE_FACEBOOK_API=""
VITE_RECAPTCHA_SITE_KEY=""

# Mercado Pago (optional)
VITE_MERCADO_PAGO_PUBLIC_KEY=""

# Firebase (optional)
# VITE_FIREBASE_PARAMS=""
# VITE_FIRABASE_VAPID_KEY=""